      "tags": ["artifact-registry", "docker-image", "api"],
      "complexity": "simple"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/images.tf:db_migrator_image",
      "type": "resource",
      "name": "db_migrator_image",
      "filePath": "iac/provider-gcp/nomad/images.tf",
