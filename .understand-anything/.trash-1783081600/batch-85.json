      "tags": ["artifact-registry", "docker-image", "migration"],
      "complexity": "simple"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/images.tf:client_proxy_image",
      "type": "resource",
      "name": "client_proxy_image",
      "filePath": "iac/provider-gcp/nomad/images.tf",
