      "tags": ["nomad", "reverse-proxy", "docker"],
      "complexity": "simple"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/main.tf:nomad_job.clean_nfs_cache",
      "type": "resource",
      "name": "nomad_job.clean_nfs_cache",
      "filePath": "iac/provider-gcp/nomad/main.tf",
