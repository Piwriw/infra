      "tags": ["nomad", "scheduler", "configuration"],
      "complexity": "simple"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/main.tf:module.ingress",
      "type": "resource",
      "name": "ingress",
      "filePath": "iac/provider-gcp/nomad/main.tf",
