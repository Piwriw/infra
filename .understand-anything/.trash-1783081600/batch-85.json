      "tags": ["module", "redis", "cache"],
      "complexity": "moderate"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/main.tf:module.client_proxy",
      "type": "resource",
      "name": "client_proxy",
      "filePath": "iac/provider-gcp/nomad/main.tf",
