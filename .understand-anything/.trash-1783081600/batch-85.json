      "tags": ["module", "ingress", "traefik", "reverse-proxy"],
      "complexity": "moderate"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/main.tf:module.api",
      "type": "resource",
      "name": "api",
      "filePath": "iac/provider-gcp/nomad/main.tf",
      "summary": "API 模块,部署 REST API 服务到 Nomad 集群,处理 sandbox 管理请求并连接 PostgreSQL/Redis/ClickHouse。",
      "tags": ["module", "api", "rest-api"],
      "complexity": "moderate"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/main.tf:module.dashboard_api",
      "type": "resource",
      "name": "dashboard_api",
      "filePath": "iac/provider-gcp/nomad/main.tf",
      "summary": "Dashboard API 模块,部署供控制台使用的 Dashboard API 服务。",
      "tags": ["module", "dashboard", "api"],
      "complexity": "moderate"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/main.tf:module.redis",
      "type": "resource",
      "name": "redis",
      "filePath": "iac/provider-gcp/nomad/main.tf",
