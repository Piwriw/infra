      "tags": ["artifact-registry", "docker-image", "edge-router"],
      "complexity": "simple"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/main.tf:nomad_job.docker_reverse_proxy",
      "type": "resource",
      "name": "nomad_job.docker_reverse_proxy",
      "filePath": "iac/provider-gcp/nomad/main.tf",
