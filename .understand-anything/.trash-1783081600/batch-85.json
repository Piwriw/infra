      "tags": ["nomad", "cleanup", "filestore"],
      "complexity": "simple"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/main.tf:nomad_scheduler_config.config",
      "type": "resource",
      "name": "nomad_scheduler_config",
