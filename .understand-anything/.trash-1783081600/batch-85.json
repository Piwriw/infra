      "tags": ["module", "client-proxy", "edge-router", "service-discovery"],
      "complexity": "moderate"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/main.tf:module.otel_collector",
      "type": "resource",
      "name": "otel_collector",
      "filePath": "iac/provider-gcp/nomad/main.tf",
