      "tags": ["module", "opentelemetry", "observability"],
      "complexity": "moderate"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/main.tf:module.otel_collector_nomad_server",
      "type": "resource",
      "name": "otel_collector_nomad_server",
      "filePath": "iac/provider-gcp/nomad/main.tf",
