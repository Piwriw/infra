{
  "nodes": [
    {
      "id": "resource:iac/provider-gcp/nomad/images.tf",
      "type": "resource",
      "name": "images.tf",
      "filePath": "iac/provider-gcp/nomad/images.tf",
      "summary": "声明 GCP Artifact Registry 中各服务容器镜像的 data source,供 Nomad Job 拉取 API、db_migrator、docker_reverse_proxy、client_proxy、clickhouse_migrator、dashboard_api 等镜像。",
      "tags": ["terraform", "artifact-registry", "container-images", "infrastructure"],
      "complexity": "simple"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/main.tf",
      "type": "resource",
      "name": "main.tf",
      "filePath": "iac/provider-gcp/nomad/main.tf",
      "summary": "Nomad 主入口,编排 API、Dashboard API、Client Proxy、Redis、OTel Collector、Loki、Orchestrator、Template Manager、ClickHouse 等模块与 Secret Manager、IAM、Scheduler 等 GCP/Nomad 资源。",
      "tags": ["terraform", "nomad", "infrastructure", "orchestration", "deployment"],
      "complexity": "complex"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/moved.tf",
      "type": "resource",
      "name": "moved.tf",
      "filePath": "iac/provider-gcp/nomad/moved.tf",
      "summary": "Terraform `moved` 块集合,用于将已有的 Nomad Job 与子模块资源重命名/重组到新位置(例如将多个 nomad_job 移入对应 module),无需销毁重建。",
      "tags": ["terraform", "state-migration", "refactor", "infrastructure"],
      "complexity": "moderate"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/variables.tf",
      "type": "resource",
      "name": "variables.tf",
      "filePath": "iac/provider-gcp/nomad/variables.tf",
      "summary": "Nomad 模块的输入变量集合(99 个),涵盖环境/区域/节点池、API/Orchestrator/ClientProxy 端口与资源、ClickHouse、Loki、OTel、Secret、GCS Token 等所有可调参数。",
      "tags": ["terraform", "variables", "configuration", "infrastructure"],
      "complexity": "complex"
    },
    {
      "id": "resource:iac/provider-gcp/nomad/images.tf:api_image",
      "type": "resource",
      "name": "api_image",
      "filePath": "iac/provider-gcp/nomad/images.tf",
