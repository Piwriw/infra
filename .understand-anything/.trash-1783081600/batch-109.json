    {
      "id": "config:packages/local-dev/grafana-datasources.yaml",
      "type": "config",
      "name": "grafana-datasources.yaml",
      "filePath": "packages/local-dev/grafana-datasources.yaml",
      "summary": "Grafana 数据源供应配置,默认删除内置 Prometheus,注册 Mimir (Prometheus 类型)、Tempo (trace 查询入口) 与 Loki 三个数据源,启用匿名访问并设置 Tempo 为默认。",
      "tags": ["configuration", "observability", "grafana", "datasource-provisioning"],
      "complexity": "moderate"
    },
    {
      "id": "config:packages/local-dev/mimir.yaml",
      "type": "config",
      "name": "mimir.yaml",
      "filePath": "packages/local-dev/mimir.yaml",
      "summary": "Mimir 长期指标的本地配置,使用文件系统后端、关闭多租户,定义 compactor、distributor、ingester、store_gateway 等组件的最小化参数以支持演示场景。",
      "tags": ["configuration", "observability", "metrics", "mimir", "local-dev"],
      "complexity": "moderate",
      "languageNotes": "使用 memberlist kvstore 简化本地部署的 ring 通信,所有存储路径落在 /tmp 下以便快速清理。"
    },
    {
      "id": "config:packages/local-dev/otel-collector.yaml",
      "type": "config",
      "name": "otel-collector.yaml",
      "filePath": "packages/local-dev/otel-collector.yaml",
      "summary": "OpenTelemetry Collector 配置,通过 OTLP gRPC/HTTP 接收 traces/metrics/logs,按不同 pipeline 分别转发到 Tempo、Mimir、Loki 以及 ClickHouse,并启用 health_check、pprof、zpages 扩展。",
      "tags": ["configuration", "observability", "opentelemetry", "pipeline", "local-dev"],
      "complexity": "moderate",
      "languageNotes": "使用 filter/external_metrics 处理器仅匹配 e2b.* 前缀的指标写入 ClickHouse,实现指标分流。"
    },
    {
      "id": "config:packages/local-dev/tempo.yaml",
      "type": "config",
      "name": "tempo.yaml",
      "filePath": "packages/local-dev/tempo.yaml",
      "summary": "Tempo 分布式追踪的本地配置,启用 stream_over_http_enabled,接入 jaeger/zipkin/otlp/opencensus 多协议接收器,并配置 metrics_generator 通过 remote_write 推送 service-graphs、span-metrics 与 local-blocks 到 Mimir。",
      "tags": ["configuration", "observability", "tracing", "tempo", "local-dev"],
      "complexity": "complex",
      "languageNotes": "通过 overrides.defaults.cost_attribution.dimensions 将 span.http.target 重映射为 service_route 自定义标签,实现成本归因。"
    },
    {
      "id": "config:packages/local-dev/vector.toml",
      "type": "config",
      "name": "vector.toml",
      "filePath": "packages/local-dev/vector.toml",
      "summary": "Vector 日志采集器配置,从 HTTP 服务器 (30006) 接收 NDJSON 日志,通过 VRL 脚本统一 sandboxID/buildID/envID/teamID 等字段命名,过滤内部日志后推送至 Loki 并附带多维标签。",
      "tags": ["configuration", "observability", "logging", "vector", "etl"],
      "complexity": "complex",
      "languageNotes": "使用 remap transform 将下划线字段 (sandbox_id) 与点号字段 (sandbox.id) 标准化为驼峰命名 (sandboxID),并通过 route transform 分离 .internal=true 的内部日志。"
    }
  ],
