    {
      "id": "schema:packages/envd/internal/services/legacy/legacyfilesystem.proto",
      "type": "schema",
      "name": "legacyfilesystem.proto",
      "filePath": "packages/envd/internal/services/legacy/legacyfilesystem.proto",
      "summary": "legacy 文件系统服务的 Protocol Buffers 定义，定义 Filesystem gRPC 服务（Stat、MakeDir、Move、ListDir、Remove、WatchDir 等 RPC）以及相关请求/响应消息、文件类型和事件类型枚举。冻结的旧版协议，用于保持与存在 Python SDK bug 期间的旧客户端兼容。",
      "tags": ["protobuf", "schema-definition", "grpc-service", "filesystem", "legacy", "api-schema"],
      "complexity": "moderate"
    },
    {
      "id": "schema:packages/envd/internal/services/legacy/legacyprocess.proto",
      "type": "schema",
      "name": "legacyprocess.proto",
      "filePath": "packages/envd/internal/services/legacy/legacyprocess.proto",
      "summary": "legacy 进程管理服务的 Protocol Buffers 定义，定义 Process gRPC 服务（List、Connect、Start、Update、StreamInput、SendInput、SendSignal 等 RPC），以及进程配置、PTY、事件流、信号枚举等消息类型。冻结的旧版协议。",
      "tags": ["protobuf", "schema-definition", "grpc-service", "process-management", "legacy", "api-schema"],
      "complexity": "moderate"
    },
    {
      "id": "document:packages/envd/internal/services/legacy/readme.md",
