      "tags": ["service", "clickhouse", "batcher", "data-pipeline", "feature-flags"],
      "complexity": "complex",
      "languageNotes": "与 events/delivery.go 共用 ClickhouseDelivery/GatedClickhouseDelivery 命名模式，方法集为 Push/Close。"
    },

