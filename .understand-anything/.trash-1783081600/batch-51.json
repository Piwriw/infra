    {
      "id": "file:packages/clickhouse/pkg/batcher/batcher.go",
      "type": "file",
      "name": "batcher.go",
      "filePath": "packages/clickhouse/pkg/batcher/batcher.go",
      "summary": "通用的泛型批量处理器（generic Batcher），按 MaxBatchSize 或 MaxDelay 触发批量刷新，并通过 OpenTelemetry 暴露队列长度、刷新时延等指标。它是 clickhouse 包内所有事件/统计批量写入 ClickHouse 的基础设施。",
      "tags": ["utility", "batcher", "buffering", "telemetry", "data-pipeline"],
      "complexity": "complex",
      "languageNotes": "使用 Go 泛型（type parameter T），通过 channel + sync.RWMutex 实现并发安全的入队与刷新，使用 ticker 实现基于时间的刷新策略。"
    },
    {
      "id": "file:packages/clickhouse/pkg/batcher/batcher_test.go",
      "type": "file",
      "name": "batcher_test.go",
      "filePath": "packages/clickhouse/pkg/batcher/batcher_test.go",
      "summary": "针对 Batcher 的单元测试，覆盖 Start/Stop、重复启动/停止、队列满丢弃、MaxBatchSize/MaxDelay 触发、并发 Push 及队列容量等场景。包含被生产代码（events/hoststats delivery）复用的测试辅助构造逻辑。",
      "tags": ["test", "batcher", "concurrency", "unit-test"],
      "complexity": "complex",
      "languageNotes": "使用 t.Parallel 进行并行测试，wait group「wg.Go」与 atomic 计数器验证并发 Push 行为。"
    },
    {
      "id": "file:packages/clickhouse/pkg/events/delivery.go",
      "type": "file",
      "name": "delivery.go",
      "filePath": "packages/clickhouse/pkg/events/delivery.go",
      "summary": "sandbox 事件（sandbox events）的 ClickHouse 投递层。基于 Batcher 聚合事件并通过 prepared batch 批量插入 ClickHouse，同时提供受 feature flag 控制的 GatedClickhouseDelivery 包装器以做开关。",
      "tags": ["service", "clickhouse", "batcher", "data-pipeline", "feature-flags"],
      "complexity": "complex",
      "languageNotes": "实现 Publish/Close 接口；通过 trace.WithAttributes 在 batchInserter 上开启 OTel span 记录每次批量插入。"
    },
