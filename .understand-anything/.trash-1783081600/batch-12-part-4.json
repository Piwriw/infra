        "nfs-proxy",
        "sandbox-mount",
        "volume",
        "observer"
      ],
      "complexity": "complex",
      "languageNotes": "chrootsByLifecycleID 按 sandbox lifecycle 跟踪挂载；网络释放时统一卸载并增加 unmounts counter；OTEL 暴露 mounts/unmounts/gauge。"
    },
