      "filePath": "iac/provider-aws/init/repositories.tf",
      "summary": "Terraform 配置 AWS ECR 镜像仓库，为 client-proxy、clickhouse-migrator、db-migrator、api、custom-environments、dashboard-api、docker-reverse-proxy 等核心服务创建私有容器镜像仓库。",
      "tags": ["infrastructure", "aws", "ecr", "container-registry"],
      "complexity": "moderate"
    },
    {
