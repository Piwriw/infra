    {
      "id": "resource:iac/provider-aws/init/buckets.tf",
      "type": "resource",
      "name": "buckets.tf",
      "filePath": "iac/provider-aws/init/buckets.tf",
      "summary": "Terraform 配置 AWS S3 存储桶，包括 Firecracker 内核、版本、模板、模板构建缓存、Envd 流水线、BusyBox、Loki、负载均衡器日志和 ClickHouse 备份等存储桶，并配置相应的生命周期策略、加密和访问策略。",
      "tags": ["infrastructure", "aws", "s3", "storage", "firecracker"],
      "complexity": "complex"
    },
    {
      "id": "resource:iac/provider-aws/init/main.tf",
      "type": "resource",
      "name": "main.tf",
      "filePath": "iac/provider-aws/init/main.tf",
      "summary": "Terraform 入口配置，获取当前 AWS 区域和 ELB 服务账户信息，并组合调用 network 和 cloudflare 两个子模块搭建基础网络环境。",
      "tags": ["infrastructure", "aws", "module", "entry-point"],
      "complexity": "simple"
    },
    {
      "id": "resource:iac/provider-aws/init/outputs.tf",
      "type": "resource",
