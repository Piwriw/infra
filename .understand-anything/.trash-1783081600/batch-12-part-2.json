    {
      "id": "file:packages/orchestrator/pkg/localupload/handler.go",
      "type": "file",
      "name": "handler.go",
      "filePath": "packages/orchestrator/pkg/localupload/handler.go",
      "summary": "用于 STORAGE_PROVIDER=Local 模式的 PUT 上传处理器 — 校验 HMAC 签名 + 过期时间、检查路径穿越、原子写入临时文件再 rename。",
      "tags": [
        "upload-handler",
        "hmac",
        "filesystem"
      ],
      "complexity": "moderate",
      "languageNotes": "在没有 GCS/S3 时把客户端上传落到本地磁盘；HMAC 令牌防止未授权写入；tempfile+rename 模式避免半截文件。"
    },
    {
      "id": "file:packages/orchestrator/pkg/localupload/handler_test.go",
      "type": "file",
      "name": "handler_test.go",
      "filePath": "packages/orchestrator/pkg/localupload/handler_test.go",
      "summary": "localupload.Handler 的单元测试套件 — 覆盖 HMAC 成功、错误方法、缺失/无效参数、过期/不同路径 token、路径穿越、覆盖和嵌套目录创建。",
      "tags": [
        "test",
        "upload-handler",
        "hmac"
      ],
      "complexity": "moderate"
    },
    {
      "id": "file:packages/orchestrator/pkg/metrics/host.go",
      "type": "file",
      "name": "host.go",
      "filePath": "packages/orchestrator/pkg/metrics/host.go",
      "summary": "HostMetrics 后台采样器 — 用 gopsutil 采集 CPU/内存/磁盘快照，请求路径通过读锁非阻塞读取最近一次缓存样本。",
      "tags": [
        "metrics",
        "host-stats",
        "background-sampler"
      ],
      "complexity": "moderate",
      "languageNotes": "采样间隔 10 秒，CPU 计数器差分依赖于 ticker 间隔；过滤掉 /boot、/dev/loop、/dev/zram 虚拟盘。"
    },
    {
      "id": "file:packages/orchestrator/pkg/metrics/sandboxes.go",
      "type": "file",
      "name": "sandboxes.go",
      "filePath": "packages/orchestrator/pkg/metrics/sandboxes.go",
      "summary": "SandboxObserver 周期观察所有 sandbox metrics（CPU/内存/磁盘），依据 envd 版本兼容性切换版本并导出 OTEL gauge；检测 host-sandbox 时钟漂移。",
      "tags": [
        "metrics",
        "otel",
        "callback-observer",
        "sandbox-stats"
      ],
      "complexity": "complex",
      "languageNotes": "使用 errgroup 并发抓取，遵守 envd 最低版本门控 (0.1.5/0.1.3/0.2.4/0.5.9)；clock drift > 5s 报警。"
    },
