      "type": "file",
      "name": "info.go",
      "filePath": "packages/orchestrator/pkg/dummyserver/info.go",
      "summary": "实现 orchestratorinfo.InfoServiceServer 的静态占位版本，向 API 层返回节点 ID、service ID、版本、commit、标签、启动时间及机器信息等最小元数据，使 API 能正确路由到此 dummy orchestrator。",
      "tags": ["grpc-handler", "info-service", "dummy", "server", "metadata"],
      "complexity": "moderate",
      "languageNotes": "通过嵌入手工的 UnimplementedInfoServiceServer 结构体获得前向兼容的默认 Unimplemented 响应。"
    },
