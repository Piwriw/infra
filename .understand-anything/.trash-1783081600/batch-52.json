    {
      "id": "file:packages/orchestrator/pkg/dummyserver/sandbox.go",
      "type": "file",
      "name": "sandbox.go",
      "filePath": "packages/orchestrator/pkg/dummyserver/sandbox.go",
      "summary": "实现 orchestrator.SandboxServiceServer 的内存占位版本：Create/Update/List/Delete/Pause 等控制面调用仅维护内存中 RunningSandbox 映射，Checkpoint 与 ListCachedBuilds 返回 Unimplemented，供本地/CI 场景无需 Firecracker 即可联调 API。",
      "tags": ["grpc-handler", "sandbox-service", "dummy", "in-memory", "server"],
      "complexity": "moderate",
      "languageNotes": "用 sync.Mutex 保护 map[string]*orchestrator.RunningSandbox，并在 List/Create 时使用 proto.Clone 返回深拷贝以避免外部修改内部状态。"
    },
    {
      "id": "class:packages/orchestrator/pkg/dummyserver/sandbox.go:SandboxServer",
      "type": "class",
      "name": "SandboxServer",
      "filePath": "packages/orchestrator/pkg/dummyserver/sandbox.go",
      "lineRange": [27, 34],
      "summary": "SandboxServiceServer 的内存实现，持有 clientID 与受 mutex 保护的 RunningSandbox 映射，支持基础生命周期与列出操作。",
      "tags": ["data-model", "grpc-handler", "sandbox-service", "server", "in-memory"],
      "complexity": "moderate"
    },
    {
      "id": "function:packages/orchestrator/pkg/dummyserver/sandbox.go:NewSandbox",
