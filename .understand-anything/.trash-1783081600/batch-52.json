{
  "nodes": [
    {
      "id": "file:packages/orchestrator/cmd/dummy-orchestrator/main.go",
      "type": "file",
      "name": "main.go",
      "filePath": "packages/orchestrator/cmd/dummy-orchestrator/main.go",
      "summary": "dummy-orchestrator 二进制入口点，用于在无法运行真实 Linux-only orchestrator 的平台（如 macOS）上提供 gRPC 控制面的占位实现，便于本地 API 开发与端到端联调。",
      "tags": ["entry-point", "grpc-server", "orchestrator", "service", "local-dev"],
      "complexity": "complex",
      "languageNotes": "通过 net.Listener 启动 gRPC 与 HTTP 健康检查两套监听器，并用 signal.NotifyContext + errgroup 风格的双 channel 实现 graceful shutdown。"
    },
    {
      "id": "function:packages/orchestrator/cmd/dummy-orchestrator/main.go:main",
      "type": "function",
      "name": "main",
      "filePath": "packages/orchestrator/cmd/dummy-orchestrator/main.go",
      "lineRange": [42, 162],
      "summary": "解析环境变量，构造 SandboxServer 与 InfoServer，注册 SandboxService/ChunkService/VolumeService/InfoService 与 gRPC health server，并并发运行 gRPC 与 HTTP 服务器，处理信号优雅关闭。",
      "tags": ["entry-point", "grpc-server", "lifecycle", "signal-handling"],
      "complexity": "complex"
    },
    {
      "id": "function:packages/orchestrator/cmd/dummy-orchestrator/main.go:envOrDefault",
